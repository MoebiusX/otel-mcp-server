{
  "uid": "kx-database-health",
  "title": "KrystalineX Database Health",
  "description": "PostgreSQL monitoring: connections, query performance, replication, storage",
  "tags": ["krystalinex", "database", "postgresql"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "{{datname}} - {{state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "title": "Connection Utilization %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count) / pg_settings_max_connections * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Max Connections Setting",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "pg_settings_max_connections"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Query Latency (Transactions)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"krystalinex\"}[5m])",
          "legendFormat": "commits/s"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"krystalinex\"}[5m])",
          "legendFormat": "rollbacks/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Rows Operations Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched{datname=\"krystalinex\"}[5m])",
          "legendFormat": "fetched/s"
        },
        {
          "expr": "rate(pg_stat_database_tup_inserted{datname=\"krystalinex\"}[5m])",
          "legendFormat": "inserted/s"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{datname=\"krystalinex\"}[5m])",
          "legendFormat": "updated/s"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{datname=\"krystalinex\"}[5m])",
          "legendFormat": "deleted/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Database Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"krystalinex\"}",
          "legendFormat": "krystalinex"
        },
        {
          "expr": "pg_database_size_bytes{datname=\"kong\"}",
          "legendFormat": "kong"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{datname=\"krystalinex\"} / (pg_stat_database_blks_hit{datname=\"krystalinex\"} + pg_stat_database_blks_read{datname=\"krystalinex\"}) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    }
  ]
}
